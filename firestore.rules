rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write renders
    match /renders/{renderId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow users to read and write projects
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    // Allow users to read and write characters (Visual DNA)
    match /visualDna/{dnaId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/visualDna/{dnaId} {
      allow read, write: if request.auth != null;
    }

    // User Settings
    match /userSettings/{userId} {
      allow read, write: if request.auth != null;
    }

    // Credits
    match /creditBalances/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /creditTransactions/{txId} {
      allow read, write: if request.auth != null;
    }

    // Agents
    match /agents/{agentId} {
      allow read, write: if request.auth != null;
    }

    // Render Queue Jobs
    match /renderJobs/{jobId} {
      allow read, write: if request.auth != null;
    }
  }
}
